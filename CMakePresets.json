{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": { "MCPP_BUILD_TESTS": "ON" }
    },
    {
      "name": "clang-debug",
      "inherits": "base",
      "displayName": "Clang Debug + ASan/UBSan",
      "environment": { "CXX": "clang++", "CC": "clang" },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "MCPP_ASAN": "ON"
      }
    },
    {
      "name": "clang-release",
      "inherits": "base",
      "displayName": "Clang Release (fast-math)",
      "environment": { "CXX": "clang++", "CC": "clang" },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Release",
        "MCPP_FAST_MATH": "ON"
      }
    },
    {
      "name": "gcc-debug",
      "inherits": "base",
      "displayName": "GCC Debug",
      "environment": { "CXX": "g++", "CC": "gcc" },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "gcc-release",
      "inherits": "base",
      "displayName": "GCC Release (fast-math)",
      "environment": { "CXX": "g++", "CC": "gcc" },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release",
        "MCPP_FAST_MATH": "ON"
      }
    },
    {
      "name": "clang-fuzz",
      "inherits": "base",
      "displayName": "Clang fuzz targets (libFuzzer + ASan/UBSan)",
      "environment": { "CXX": "clang++", "CC": "clang" },
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "MCPP_BUILD_TESTS": "OFF",
        "MCPP_FUZZ": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "clang-debug",   "configurePreset": "clang-debug" },
    { "name": "clang-release", "configurePreset": "clang-release" },
    { "name": "gcc-debug",     "configurePreset": "gcc-debug" },
    { "name": "gcc-release",   "configurePreset": "gcc-release" },
    { "name": "clang-fuzz",    "configurePreset": "clang-fuzz" }
  ],
  "testPresets": [
    { "name": "clang-debug",   "configurePreset": "clang-debug",   "output": { "outputOnFailure": true } },
    { "name": "clang-release", "configurePreset": "clang-release", "output": { "outputOnFailure": true } },
    { "name": "gcc-debug",     "configurePreset": "gcc-debug",     "output": { "outputOnFailure": true } },
    { "name": "gcc-release",   "configurePreset": "gcc-release",   "output": { "outputOnFailure": true } }
  ]
}
